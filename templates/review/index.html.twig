{% extends 'base.html.twig' %}

{% block title %}Vélemények | TrustIndex{% endblock %}

{% block body %}

<div class="hero text-center mb-5">

    <h1 class="display-5 fw-bold mb-3">
        <i class="bi bi-chat-square-text"></i>
        Vélemények
    </h1>

    <p class="lead text-muted">
        Böngészd az összes beküldött véleményt.
    </p>

</div>
<a
    href="{{ path('review_export') }}"
    class="btn btn-success">

    <i class="bi bi-file-earmark-spreadsheet"></i>

    CSV export (az összeset exportálja)

</a>
<div class="card shadow-sm mb-4">

    <div class="card-body">

        {{ form_start(filterForm) }}

        <div class="row align-items-end">

            <div class="col-md-9">

                <label class="form-label">
                    Cégnév keresése
                </label>

                {{ form_widget(filterForm.search) }}

            </div>

            <div class="col-md-2">

                <label class="form-label">
                    Oldalanként
                </label>

                {{ form_widget(filterForm.limit) }}

            </div>

            <div class="col-md-1 d-grid">

                <button class="btn btn-warning">

                    <i class="bi bi-search"></i>

                </button>

            </div>

        </div>

        {{ form_end(filterForm) }}

    </div>

</div>
<div class="d-flex justify-content-between align-items-center mt-4 mb-3">

    <div class="text-muted">

        {% if reviews.getTotalItemCount > 0 %}

            {% set from = ((reviews.currentPageNumber - 1) * reviews.itemNumberPerPage) + 1 %}
            {% set to = from + reviews|length - 1 %}

            Megjelenítve:
            <strong>{{ from }}–{{ to }}</strong>
            /
            <strong>{{ reviews.getTotalItemCount }}</strong>
            vélemény

        {% endif %}

    </div>

</div>
<div class="mt-4 d-flex justify-content-center">

    {{ knp_pagination_render(reviews) }}

</div>
<div class="card shadow-sm">

    <div class="card-body p-0">

        <div class="table-responsive">

            <table class="table table-hover align-middle mb-0">

                <thead class="table-light">

                <tr>

                    <th>

                        {{ knp_pagination_sortable(
                            reviews,
                            'Cégnév',
                            'review.companyName'
                        ) }}

                    </th>

                    <th width="170">

                        {{ knp_pagination_sortable(
                            reviews,
                            'Értékelés',
                            'review.rating'
                        ) }}

                    </th>

                    <th>

                        Vélemény

                    </th>

                    <th width="180">

                        {{ knp_pagination_sortable(
                            reviews,
                            'Dátum',
                            'review.createdAt'
                        ) }}

                    </th>

                    <th width="120"></th>

                </tr>

                </thead>

                <tbody>

                {% for review in reviews %}

                    <tr>

                        <td>

                            <strong>

                                {{ review.companyName }}

                            </strong>

                        </td>

                        <td>

                            <div class="text-warning">

                                {% for i in 1..5 %}

                                    {% if i <= review.rating %}

                                        <i class="bi bi-star-fill"></i>

                                    {% else %}

                                        <i class="bi bi-star"></i>

                                    {% endif %}

                                {% endfor %}

                            </div>

                            <small class="text-muted">

                                {{ review.rating }}/5

                            </small>

                        </td>

                        <td>

                            {{ review.reviewText|u.truncate(80,'...') }}


                        </td>

                        <td>

                            {{ review.createdAt|date('Y.m.d H:i') }}

                        </td>

                        <td class="text-end">

                            <a
                                    href="{{ path('review_show', {id: review.id}) }}"
                                    class="btn btn-outline-primary btn-sm">

                                <i class="bi bi-eye"></i>

                                Részletek

                            </a>

                        </td>

                    </tr>

                {% else %}

                    <tr>

                        <td colspan="5" class="text-center py-5">

                            <i class="bi bi-chat-square-text display-5 text-muted"></i>

                            <p class="mt-3 mb-0">

                                Nincs találat.

                            </p>

                        </td>

                    </tr>

                {% endfor %}

                </tbody>

            </table>

        </div>

    </div>

</div>

<div class="mt-4 d-flex justify-content-center">

    {{ knp_pagination_render(reviews) }}

</div>

{% endblock %}