{% extends 'base.html.twig' %}

{% block title %}Cégstatisztikák | TrustIndex{% endblock %}

{% block body %}

<div class="hero text-center">

    <h1 class="display-5 fw-bold mb-3">
        <i class="bi bi-building"></i>
        Cégstatisztikák
    </h1>

    <p class="lead text-muted">
        Átlagos értékelések és beérkezett vélemények cégenként.
    </p>

</div>

{% if companies is empty %}

    <div class="alert alert-info">
        <i class="bi bi-info-circle"></i>
        Jelenleg még nincs megjeleníthető statisztika.
    </div>

{% else %}

<div class="row">

    

    {% for company in companies %}
        {% set average = company.averageRating|number_format(1) %}

        <div class="col-lg-4 col-md-6 mb-4">

            <div class="card h-100">

                <div class="card-body text-center">

                    <i class="bi bi-building-fill display-5 text-primary mb-3"></i>

                    <h3 class="mb-3">
                        {{ company.companyName }}
                    </h3>

                    <div class="display-6 fw-bold text-warning mb-2">
                        {{ average }}
                        <small class="fs-4 text-dark">/5</small>
                    </div>

                    {% set rounded = company.averageRating|round(0, 'common') %}

                    <div class="rating mb-4">

                        {% for i in 1..5 %}
                            {% if i <= rounded %}
                                <i class="bi bi-star-fill"></i>
                            {% else %}
                                <i class="bi bi-star"></i>
                            {% endif %}
                        {% endfor %}

                    </div>

                    <hr>

                    <div class="row text-center">

                        <div class="col-6">

                            <div class="text-muted small">
                                Átlagos értékelés
                            </div>

                            <div class="fw-bold fs-5 text-warning">
                                {{ average }}/5
                            </div>

                        </div>

                        <div class="col-6">

                            <div class="text-muted small">
                                Összes vélemény
                            </div>

                            <div class="fw-bold fs-5">
                                {{ company.reviewCount }}
                                vélemény
                            </div>

                        </div>

                    </div>

                </div>

            </div>

        </div>

    {% endfor %}

</div>

{% endif %}

{% endblock %}