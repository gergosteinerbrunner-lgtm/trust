<!DOCTYPE html>
<html lang="hu">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1">

    <title>{% block title %}TrustIndex Reviews{% endblock %}</title>

    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.13.1/font/bootstrap-icons.min.css" rel="stylesheet">

    <style>
        body{
            background:#f5f7fb;
        }

        .navbar-brand{
            font-weight:700;
        }

        .hero{
            background:#fff;
            border-radius:18px;
            padding:50px;
            box-shadow:0 15px 40px rgba(0,0,0,.08);
            margin-bottom:40px;
        }

        .card{
            border:none;
            border-radius:18px;
            box-shadow:0 8px 20px rgba(0,0,0,.05);
            transition:.2s;
        }

        .card:hover{
            transform:translateY(-3px);
        }

        .rating{
            color:#ffc107;
            font-size:18px;
        }

        footer{
            margin-top:80px;
        }

        .dark-mode {

            background:#1d1f21;

            color:#f8f9fa;

        }

        .dark-mode .card{

            background:#2b2d31;

            color:#f8f9fa;

        }

        .dark-mode .navbar{

            background:#16181a !important;

        }

        .dark-mode .table{

            color:#f8f9fa;

        }

        .dark-mode .table-light{

            --bs-table-bg:#343a40;

            color:white;

        }

        .dark-mode .form-control,
        .dark-mode .form-select{

            background:#343a40;

            color:white;

            border-color:#555;

        }

        .dark-mode .form-control::placeholder{

            color:#aaa;

        }

        .dark-mode .hero{

            background:#2b2d31;

        }

        .dark-mode .text-muted{

            color:#c5c5c5 !important;

        }
    </style>

    {% block stylesheets %}{% endblock %}
</head>

<body>

<nav class="navbar navbar-expand-lg navbar-dark bg-dark shadow-sm">

    <div class="container">

        <a class="navbar-brand" href="{{ path('home') }}">
            ⭐ TrustIndex
        </a>

        <button class="navbar-toggler"
                type="button"
                data-bs-toggle="collapse"
                data-bs-target="#navbar">

            <span class="navbar-toggler-icon"></span>

        </button>

        <div class="collapse navbar-collapse" id="navbar">

            <ul class="navbar-nav ms-auto">

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('review_index') }}">
                        <i class="bi bi-chat-left-text"></i>
                        Vélemények
                    </a>
                </li>

                <li class="nav-item">
                    <a class="nav-link" href="{{ path('company_index') }}">
                        <i class="bi bi-building"></i>
                        Cégek
                    </a>
                </li>

                <li class="nav-item ms-lg-3">
                    <a class="btn btn-warning"
                       href="{{ path('review_new') }}">

                        <i class="bi bi-plus-circle"></i>

                        Új vélemény

                    </a>
                </li>
                <li>
                    <button
                        id="themeToggle"
                        class="btn btn-outline-secondary">

                        <i class="bi bi-moon-stars"></i>
                    </button>
                </li>
            </ul>

        </div>

    </div>

</nav>

<div class="container py-5">

    {% for label, messages in app.flashes %}

        {% for message in messages %}

            <div class="alert alert-{{ label }} alert-dismissible fade show">

                {{ message }}

                <button class="btn-close"
                        data-bs-dismiss="alert"></button>

            </div>

        {% endfor %}

    {% endfor %}

    {% block body %}{% endblock %}

</div>

<footer class="bg-dark text-white py-4">

    <div class="container text-center">

        © {{ "now"|date("Y") }} TrustIndex Test Assignment

    </div>

</footer>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.8/dist/js/bootstrap.bundle.min.js"></script>

{% block javascripts %}{% endblock %}


<script>

    document.addEventListener('DOMContentLoaded', () => {
        const toggle = document.getElementById('themeToggle');

        if (!toggle) {
            return;
        }

        const currentTheme = localStorage.getItem('theme');

        if (currentTheme === 'dark') {
            document.body.classList.add('dark-mode');
            toggle.innerHTML = '<i class="bi bi-sun"></i>';
        }

        toggle.addEventListener('click', () => {
            document.body.classList.toggle('dark-mode');
            const isDarkMode = document.body.classList.contains('dark-mode');
            localStorage.setItem(
                'theme',
                isDarkMode ? 'dark' : 'light'
            );
            toggle.innerHTML = isDarkMode
                ? '<i class="bi bi-sun"></i>'
                : '<i class="bi bi-moon-stars"></i>';
        });

    });

</script>


</body>
</html>