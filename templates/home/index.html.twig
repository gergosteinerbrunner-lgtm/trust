{% extends 'base.html.twig' %}

{% block title %}Vélemények | TrustIndex{% endblock %}

{% block body %}

    <div class="hero text-center">

        <h1 class="display-5 fw-bold mb-3">
            ⭐ TrustIndex Reviews
        </h1>

        <p class="lead text-muted mb-4">
            Oszd meg tapasztalataidat cégekről, vagy olvasd el mások véleményét.
        </p>

        <a href="{{ path('review_new') }}" class="btn btn-warning btn-lg px-4">
            <i class="bi bi-plus-circle"></i>
            Új vélemény írása
        </a>

    </div>

    <div class="row mb-4">

        <div class="col-12">

            <div class="d-flex justify-content-center mb-5">

                <div class="d-flex gap-2 justify-content-center">

                    <a
                            href="{{ path('home', {type: 'latest'}) }}"
                            class="btn {{ type == 'latest' ? 'btn-warning' : 'btn-outline-dark' }}">

                        <i class="bi bi-clock-history"></i>

                        4 Legfrissebb

                    </a>

                    <a
                            href="{{ path('home', {type: 'top'}) }}"
                            class="btn {{ type == 'top' ? 'btn-warning' : 'btn-outline-dark' }}">

                        <i class="bi bi-trophy-fill"></i>

                        4 Legjobb értékelés

                    </a>

                </div>

            </div>

        </div>

    </div>

    {% if reviews is empty %}

        <div class="alert alert-info">

            <i class="bi bi-info-circle"></i>

            Még nem érkezett egyetlen vélemény sem.

        </div>

    {% else %}

        <div class="row">

            {% for review in reviews %}

                <div class="col-lg-6 mb-4">

                    <div class="card h-100">

                        <div class="card-body">

                            <div class="d-flex justify-content-between align-items-start mb-3">

                                <h4 class="mb-0">
                                    {{ review.companyName }}
                                </h4>

                                <div class="text-end">

                                    {% if type == 'top' %}

                                        <span class="badge bg-warning text-dark mb-1">

                                            <i class="bi bi-trophy-fill"></i>

                                            TOP

                                        </span>

                                        <br>

                                    {% endif %}

                                    <small class="text-muted">
                                        {{ review.createdAt|date('Y.m.d') }}
                                    </small>

                                </div>

                            </div>

                            <div class="rating mb-3">

                                {% for i in 1..5 %}

                                    {% if i <= review.rating %}

                                        <i class="bi bi-star-fill"></i>

                                    {% else %}

                                        <i class="bi bi-star"></i>

                                    {% endif %}

                                {% endfor %}

                            </div>

                            <p class="text-muted">

                                {{ review.reviewText|u.truncate(140, '...') }}

                            </p>

                        </div>

                        <div class="card-footer bg-white border-0">

                            <a
                                    href="{{ path('review_show', {id: review.id}) }}"
                                    class="btn btn-outline-primary">

                                Részletek

                            </a>

                        </div>

                    </div>

                </div>

            {% endfor %}

        </div>

    {% endif %}

{% endblock %}